\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{texfrog}[2025/01/01 TeXFrog: game-hopping proof management]

\RequirePackage{xcolor}
\RequirePackage{xparse}
\RequirePackage{expl3}
\RequirePackage{l3keys2e}

% ======================================================================
% expl3 implementation
% ======================================================================

\ExplSyntaxOn

% ----------------------------------------------------------------------
% Variables
% ----------------------------------------------------------------------

% Active source name (set by rendering commands)
\tl_new:N \g__tf_current_source_tl

% Active working copies of per-source data (populated by \__tf_activate_source:n)
% Ordered sequence of game labels
\seq_new:N \g__tf_games_seq

% Game name property list: label -> latex_name
\prop_new:N \g__tf_gamename_prop

% Reduction set (labels that are reductions)
\prop_new:N \g__tf_reduction_prop

% Related games property list: label -> comma-list of related labels
\prop_new:N \g__tf_related_prop

% Current mode for \tfonly:
%   0 = inactive (inside tfsource capture)
%   1 = record (recording pass)
%   2 = render (render with highlighting)
%   3 = clean (render without highlighting)
%   4 = figure
\int_new:N \g__tf_mode_int

% Current game label being rendered
\tl_new:N \g__tf_current_game_tl

% Sequential counter for \tfonly positions
\int_new:N \g__tf_pos_int

% Property list recording active positions from recording pass
% Maps position (as string) -> "1"
\prop_new:N \g__tf_recorded_prop

% Package profile: "cryptocode" or "nicodemus"
\tl_new:N \g__tf_package_tl

% Whether content is math mode (derived from package)
\bool_new:N \g__tf_math_mode_bool

% Whether package uses \\ line separators
\bool_new:N \g__tf_line_sep_bool

% Game label comment command (e.g., \pccomment for cryptocode)
\tl_new:N \g__tf_gamelabel_cmd_tl

% ----------------------------------------------------------------------
% Package options (processed via \usepackage[package=...]{texfrog})
% ----------------------------------------------------------------------

\msg_new:nnn { texfrog } { unknown-package }
  {
    Unknown~package~option~'#3'~for~texfrog;~valid~choices~are~#2.~
    Falling~back~to~'cryptocode'.
  }

\keys_define:nn { texfrog }
  {
    package .choice:,
    package / cryptocode .code:n =
      {
        \tl_gset:Nn \g__tf_package_tl { cryptocode }
        \bool_gset_true:N \g__tf_math_mode_bool
        \bool_gset_true:N \g__tf_line_sep_bool
        \tl_gset:Nn \g__tf_gamelabel_cmd_tl { \pccomment }
      },
    package / nicodemus .code:n =
      {
        \tl_gset:Nn \g__tf_package_tl { nicodemus }
        \bool_gset_false:N \g__tf_math_mode_bool
        \bool_gset_false:N \g__tf_line_sep_bool
        \tl_gclear:N \g__tf_gamelabel_cmd_tl
      },
    package / algpseudocodex .code:n =
      {
        \tl_gset:Nn \g__tf_package_tl { algpseudocodex }
        \bool_gset_false:N \g__tf_math_mode_bool
        \bool_gset_false:N \g__tf_line_sep_bool
        \tl_gset:Nn \g__tf_gamelabel_cmd_tl { \Comment }
      },
    % Custom message (rather than l3keys' generic "accepts only a fixed
    % set of choices" error) so an invalid package= value is clearly
    % reported, naming the valid choices, instead of silently falling
    % back to cryptocode's configuration with no explanation.
    package / unknown .code:n =
      {
        \msg_warning:nneee { texfrog } { unknown-package }
          { package }
          { cryptocode,~nicodemus,~algpseudocodex }
          { \exp_not:n {#1} }
        \tl_gset:Nn \g__tf_package_tl { cryptocode }
        \bool_gset_true:N \g__tf_math_mode_bool
        \bool_gset_true:N \g__tf_line_sep_bool
        \tl_gset:Nn \g__tf_gamelabel_cmd_tl { \pccomment }
      },
    package .initial:n = cryptocode,
  }

\ProcessKeysOptions { texfrog }

% Figure game list (comma list of labels for current figure rendering)
\clist_new:N \g__tf_figure_games_clist

% Flag: was the previous output a procedure header? (for deduplication)
\bool_new:N \g__tf_last_was_proc_header_bool

% Scratch box for recording pass
\box_new:N \g__tf_scratch_box

