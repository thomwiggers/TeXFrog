\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{texfrog}[2025/01/01 TeXFrog: game-hopping proof management]

\RequirePackage{xcolor}
\RequirePackage{xparse}
\RequirePackage{expl3}
\RequirePackage{l3keys2e}

% ======================================================================
% expl3 implementation
% ======================================================================

\ExplSyntaxOn

% ----------------------------------------------------------------------
% Variables
% ----------------------------------------------------------------------

% Active source name (set by rendering commands)
\tl_new:N \g__tf_current_source_tl

% Active working copies of per-source data (populated by \__tf_activate_source:n)
% Ordered sequence of game labels
\seq_new:N \g__tf_games_seq

% Game name property list: label -> latex_name
\prop_new:N \g__tf_gamename_prop

% Reduction set (labels that are reductions)
\prop_new:N \g__tf_reduction_prop

% Related games property list: label -> comma-list of related labels
\prop_new:N \g__tf_related_prop

% Current mode for \tfonly:
%   0 = inactive (inside tfsource capture)
%   1 = record (recording pass)
%   2 = render (render with highlighting)
%   3 = clean (render without highlighting)
%   4 = figure
%   5 = scan (segment-cropping pre-pass; determines which segments changed)
\int_new:N \g__tf_mode_int

% Current game label being rendered
\tl_new:N \g__tf_current_game_tl

% Sequential counter for \tfonly positions
\int_new:N \g__tf_pos_int

% Property list recording active positions from recording pass
% Maps position (as string) -> "1"
\prop_new:N \g__tf_recorded_prop

% Package profile: "cryptocode" or "nicodemus"
\tl_new:N \g__tf_package_tl

% Whether content is math mode (derived from package)
\bool_new:N \g__tf_math_mode_bool

% Whether package uses \\ line separators
\bool_new:N \g__tf_line_sep_bool

% Game label comment command (e.g., \pccomment for cryptocode)
\tl_new:N \g__tf_gamelabel_cmd_tl

% Segment cropping state
\bool_new:N \g__tf_crop_default_bool
\bool_new:N \g__tf_crop_active_bool      % effective crop for current render
\int_new:N  \g__tf_seg_int               % current segment index during a pass
\prop_new:N \g__tf_active_seg_prop       % active segment indices (scan result)
\bool_new:N \g__tf_seg_changed_bool      % did current segment change? (scan)

% --- Task 6: token-split crop-render state ---
% \g__tf_seg_endpos_prop maps segment index -> the \g__tf_pos_int value
% recorded at that segment's boundary during the scan pass (mode 5). This
% lets the crop-render pass jump \g__tf_pos_int forward across a skipped
% (stubbed) segment without executing its content, keeping \tfonly position
% counting aligned with the record pass (Pass A) for every segment that IS
% rendered afterwards.
\prop_new:N \g__tf_seg_endpos_prop
% \g__tf_seg_startline_prop maps segment index -> the algpseudocodex line
% counter (ALG@line) value recorded at that segment's opening boundary during
% the scan pass (mode 5). Used to restore ABSOLUTE line numbers in a
% cropped render: before each kept segment the counter is set to this value,
% so kept lines keep the numbers they would have in the full listing (numbers
% jump across a stub instead of renumbering contiguously). Populated only when
% the ALG@line counter exists (algpseudocodex); empty otherwise, in which case
% the setline step is a no-op.
\prop_new:N \g__tf_seg_startline_prop
% Index of the final segment (computed once the scan pass has walked the
% whole source; no trailing \tfsegment closes the last segment, so this is
% captured explicitly rather than via a boundary call).
\int_new:N  \g__tf_seg_last_int
% \g__tf_seg_bodies_seq / \g__tf_seg_caps_seq: the source token list split at
% \tfsegment{...} markers (see \__tf_split_source_segments:n below). Item
% (i+1) of \g__tf_seg_bodies_seq is segment i's body; \g__tf_seg_caps_seq
% has one fewer item (segment 0, the implicit preamble, has no caption) --
% item i of \g__tf_seg_caps_seq is segment i's caption, i >= 1.
\seq_new:N  \g__tf_seg_bodies_seq
\seq_new:N  \g__tf_seg_caps_seq
% Scratch variables for the split itself.
\tl_new:N   \l__tf_seg_split_input_tl
\seq_new:N  \l__tf_seg_matches_seq
% Final-segment closer handling (see \__tf_peel_final_closer:). The final
% segment normally carries the source's environment closer (\end{algorithmic}
% etc.); we peel that closer off so the segment's leading content can crop like
% any interior segment while the closer is always re-emitted. The closer is
% matched by ENVIRONMENT NAME (the outer \begin{...} from segment 0), never a
% bare \end{...}, so an inner \end{align}/\end{cases} in a math line is safe.
\tl_new:N   \l__tf_seg_final_body_tl
\tl_new:N   \l__tf_seg_content_tl
\tl_new:N   \l__tf_outer_env_tl
\tl_new:N   \g__tf_seg_closer_tl
\bool_new:N \g__tf_final_croppable_bool
\regex_new:N \l__tf_seg_closer_regex
% Precompiled matchers for a \tfsegment{caption} marker. Braces are matched
% via the escaped-character-literal form (\{ / \}) so they need no manual
% balancing in this source file, and match the caption text regardless of
% its tokens' actual category codes.
%
% NOTE 1: the \c{...} csname-regex argument must be the BARE name with no
% leading backslash (mirroring the docs' own \c{begin} example matching
% \begin) -- \c{\tfsegment} would be wrong: inside \c{...}, "\t" is itself
% a recognized regex escape (horizontal tab), so \c{\tfsegment} silently
% matches a control sequence whose name starts with a TAB character, never
% \tfsegment. (Verified empirically against l3regex; some other \c{...}
% uses elsewhere in this file, e.g. \c{\item}/\c{\State}, happen to still
% work despite the leading backslash -- \i and \S are not recognized
% single-character escapes the same way \t is -- but the bare form used
% here is the only form actually documented to be correct.)
%
% NOTE 2: two SEPARATE regexes are used -- one with no capturing group for
% \regex_split:NVN, one with a capturing group for \regex_extract_all:NVN
% -- rather than sharing a single capturing-group regex for both. Verified
% empirically that \regex_split:nnN/NVN on a regex WITH a capturing group
% interleaves the captured text as EXTRA items in the split result (each
% match contributes both its capture and the following "between" text as
% separate sequence items), not just the between-match bodies. Reusing one
% regex for both operations silently produced misaligned segment bodies.
\regex_new:N \g__tf_seg_marker_regex
\regex_set:Nn \g__tf_seg_marker_regex { \c{tfsegment} \{ [^\{\}]* \} }
\regex_new:N \g__tf_seg_caption_regex
\regex_set:Nn \g__tf_seg_caption_regex { \c{tfsegment} \{ ( [^\{\}]* ) \} }
% Captures the environment name of each \begin{name} (used to find segment 0's
% outer environment, whose matching \end{name} is the final segment's closer).
\regex_new:N \g__tf_begin_name_regex
\regex_set:Nn \g__tf_begin_name_regex { \c{begin} \s* \{ ( [^\{\}]* ) \} }

% ----------------------------------------------------------------------
% Package options (processed via \usepackage[package=...]{texfrog})
% ----------------------------------------------------------------------

\msg_new:nnn { texfrog } { unknown-package }
  {
    Unknown~package~option~'#3'~for~texfrog;~valid~choices~are~#2.~
    Falling~back~to~'cryptocode'.
  }

\keys_define:nn { texfrog }
  {
    package .choice:,
    package / cryptocode .code:n =
      {
        \tl_gset:Nn \g__tf_package_tl { cryptocode }
        \bool_gset_true:N \g__tf_math_mode_bool
        \bool_gset_true:N \g__tf_line_sep_bool
        \tl_gset:Nn \g__tf_gamelabel_cmd_tl { \pccomment }
      },
    package / nicodemus .code:n =
      {
        \tl_gset:Nn \g__tf_package_tl { nicodemus }
        \bool_gset_false:N \g__tf_math_mode_bool
        \bool_gset_false:N \g__tf_line_sep_bool
        \tl_gclear:N \g__tf_gamelabel_cmd_tl
      },
    package / algpseudocodex .code:n =
      {
        \tl_gset:Nn \g__tf_package_tl { algpseudocodex }
        \bool_gset_false:N \g__tf_math_mode_bool
        \bool_gset_false:N \g__tf_line_sep_bool
        \tl_gset:Nn \g__tf_gamelabel_cmd_tl { \Comment }
      },
    % Custom message (rather than l3keys' generic "accepts only a fixed
    % set of choices" error) so an invalid package= value is clearly
    % reported, naming the valid choices, instead of silently falling
    % back to cryptocode's configuration with no explanation.
    package / unknown .code:n =
      {
        \msg_warning:nneee { texfrog } { unknown-package }
          { package }
          { cryptocode,~nicodemus,~algpseudocodex }
          { \exp_not:n {#1} }
        \tl_gset:Nn \g__tf_package_tl { cryptocode }
        \bool_gset_true:N \g__tf_math_mode_bool
        \bool_gset_true:N \g__tf_line_sep_bool
        \tl_gset:Nn \g__tf_gamelabel_cmd_tl { \pccomment }
      },
    package .initial:n = cryptocode,
  }

\ProcessKeysOptions { texfrog }

% Figure game list (comma list of labels for current figure rendering)
\clist_new:N \g__tf_figure_games_clist

% Flag: was the previous output a procedure header? (for deduplication)
\bool_new:N \g__tf_last_was_proc_header_bool

% Scratch box for recording pass
\box_new:N \g__tf_scratch_box

