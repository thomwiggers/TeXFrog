\cs_generate_variant:Nn \seq_gclear_new:N { c }
\cs_generate_variant:Nn \seq_gput_right:Nn { cn }
\cs_generate_variant:Nn \seq_gset_eq:NN { Nc }
\cs_generate_variant:Nn \prop_gclear_new:N { c }
\cs_generate_variant:Nn \prop_gput:Nnn { cnn }
\cs_generate_variant:Nn \prop_gset_eq:NN { Nc }
\cs_generate_variant:Nn \prop_get:NnNTF { cnNTF }

% ======================================================================
% Source activation (copies per-source data into active working vars)
% ======================================================================

\cs_new_protected:Nn \__tf_activate_source:n
  {
    \tl_gset:Nn \g__tf_current_source_tl { #1 }
    \seq_gset_eq:Nc \g__tf_games_seq { g__tf_source_ #1 _games_seq }
    \prop_gset_eq:Nc \g__tf_gamename_prop { g__tf_source_ #1 _gamename_prop }
    \prop_gset_eq:Nc \g__tf_reduction_prop { g__tf_source_ #1 _reduction_prop }
    \prop_gset_eq:Nc \g__tf_related_prop { g__tf_source_ #1 _related_prop }
  }

% ======================================================================
% Game registration (per-source)
% ======================================================================

% \tfgames{source}{G0, G1, Red1, G2, G3}
\NewDocumentCommand{\tfgames}{ m m }
  {
    \seq_gclear_new:c { g__tf_source_ #1 _games_seq }
    \prop_gclear_new:c { g__tf_source_ #1 _gamename_prop }
    \prop_gclear_new:c { g__tf_source_ #1 _reduction_prop }
    \prop_gclear_new:c { g__tf_source_ #1 _related_prop }
    \clist_map_inline:nn { #2 }
      {
        \seq_gput_right:cn { g__tf_source_ #1 _games_seq } { ##1 }
      }
  }

% \tfgamename{source}{label}{name} (define) or \tfgamename{label} (lookup, active source)
% or \tfgamename{source}{label} (lookup, explicit source)
\NewDocumentCommand{\tfgamename}{ m g g }
  {
    \IfNoValueTF { #2 }
      { \__tf_gamename_use:n { #1 } } % 1 arg: lookup from active source
      {
        \IfNoValueTF { #3 }
          { \__tf_gamename_source_use:nn { #1 } { #2 } } % 2 args: lookup with explicit source
          { \prop_gput:cnn { g__tf_source_ #1 _gamename_prop } { #2 } { #3 } } % 3 args: define
      }
  }

% \tfreduction{source}{label}
\NewDocumentCommand{\tfreduction}{ m m }
  {
    \prop_gput:cnn { g__tf_source_ #1 _reduction_prop } { #2 } { 1 }
  }

% \tfrelatedgames{source}{label}{games}
\NewDocumentCommand{\tfrelatedgames}{ m m m }
  {
    \prop_gput:cnn { g__tf_source_ #1 _related_prop } { #2 } { #3 }
  }

