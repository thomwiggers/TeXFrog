% Internal lookup using active source (1-arg form, used inside tfsource body)
\cs_new_protected:Nn \__tf_gamename_use:n
  {
    \prop_get:NnNTF \g__tf_gamename_prop { #1 } \l_tmpa_tl
      { \ensuremath{ \tl_use:N \l_tmpa_tl } }
      { \textbf{??#1??} }
  }

% Lookup with explicit source (2-arg form)
\cs_new_protected:Nn \__tf_gamename_source_use:nn
  {
    \prop_get:cnNTF { g__tf_source_ #1 _gamename_prop } { #2 } \l_tmpa_tl
      { \ensuremath{ \tl_use:N \l_tmpa_tl } }
      { \textbf{??#1:#2??} }
  }

