% ======================================================================
% Tag parsing and range resolution
% ======================================================================

% Resolve a tag string (e.g., "G0,G2-G4") to a property list
% where each matching label maps to "1".
% Result stored in \l__tf_resolved_tags_prop
\prop_new:N \l__tf_resolved_tags_prop

% Helper: find index of label in games sequence. Returns -1 if not found.
\int_new:N \l__tf_idx_int

\cs_new:Nn \__tf_find_index:nN
  {
    \int_set:Nn #2 { -1 }
    \int_zero:N \l__tf_idx_int
    \seq_map_inline:Nn \g__tf_games_seq
      {
        \str_if_eq:nnT { ##1 } { #1 }
          {
            \int_set_eq:NN #2 \l__tf_idx_int
            \seq_map_break:
          }
        \int_incr:N \l__tf_idx_int
      }
  }

\int_new:N \l__tf_range_start_int
\int_new:N \l__tf_range_end_int
\int_new:N \l__tf_range_i_int

\cs_new_protected:Nn \__tf_resolve_tags:n
  {
    \prop_clear:N \l__tf_resolved_tags_prop
    \clist_map_inline:nn { #1 }
      {
        \__tf_resolve_single_tag:n { ##1 }
      }
  }

% Process a single tag token (may be a label or a range like G0-G3).
\tl_new:N \l__tf_tag_token_tl
\cs_new_protected:Nn \__tf_resolve_single_tag:n
  {
    \tl_set:Nn \l__tf_tag_token_tl { #1 }
    % Check if it contains a hyphen by trying to split
    \__tf_try_range:nTF { #1 }
      { } % range was resolved, nothing more to do
      {
        % Not a range — treat as a literal label
        \prop_put:Nnn \l__tf_resolved_tags_prop { #1 } { 1 }
      }
  }

% Try to interpret token as a range. Returns true if successful.
% Strategy: try splitting on "-" at each position.
\prg_new_conditional:Nnn \__tf_try_range:n { TF }
  {
    \__tf_try_range_aux:n { #1 }
  }

\tl_new:N \l__tf_range_before_tl
\tl_new:N \l__tf_range_after_tl
\bool_new:N \l__tf_range_found_bool

\cs_new_protected:Nn \__tf_try_range_aux:n
  {
    \bool_set_false:N \l__tf_range_found_bool
    % Use regex to find "X-Y" pattern where X and Y are non-empty
    \tl_set:Nn \l_tmpa_tl { #1 }
    % Simple approach: split on first hyphen
    \exp_args:NnV \__tf_split_on_hyphen:nnN { #1 } \l_tmpa_tl \l__tf_range_found_bool
    \bool_if:NTF \l__tf_range_found_bool
      { \prg_return_true: }
      { \prg_return_false: }
  }

% Split string on hyphen, try each split point.
% For simplicity, try the first hyphen position.
\cs_new_protected:Nn \__tf_split_on_hyphen:nnN
  {
    % We'll manually scan for hyphens in the string
    \bool_set_false:N #3
    \str_set:Nn \l_tmpa_str { #1 }
    \int_step_inline:nn { \str_count:N \l_tmpa_str }
      {
        \bool_if:NF #3
          {
            \str_if_eq:eeT { \str_item:Nn \l_tmpa_str { ##1 } } { - }
              {
                % Try split at position ##1
                \tl_set:Ne \l__tf_range_before_tl
                  { \str_range:Nnn \l_tmpa_str { 1 } { \int_eval:n { ##1 - 1 } } }
                \tl_set:Ne \l__tf_range_after_tl
                  { \str_range:Nnn \l_tmpa_str { \int_eval:n { ##1 + 1 } } { -1 } }
                % Check both are valid labels
                \int_set:Nn \l__tf_range_start_int { -1 }
                \int_set:Nn \l__tf_range_end_int { -1 }
                \exp_args:NV \__tf_find_index:nN \l__tf_range_before_tl \l__tf_range_start_int
                \exp_args:NV \__tf_find_index:nN \l__tf_range_after_tl \l__tf_range_end_int
                \bool_lazy_and:nnT
                  { \int_compare_p:nNn \l__tf_range_start_int > { -1 } }
                  { \int_compare_p:nNn \l__tf_range_end_int > { -1 } }
                  {
                    % Valid range — add all labels from start to end
                    \int_step_inline:nnn
                      { \l__tf_range_start_int }
                      { \l__tf_range_end_int }
                      {
                        \prop_put:Nen \l__tf_resolved_tags_prop
                          { \seq_item:Nn \g__tf_games_seq { \int_eval:n { ####1 + 1 } } }
                          { 1 }
                      }
                    \bool_set_true:N #3
                  }
              }
          }
      }
  }

% Variant needed for putting expanded key
\cs_generate_variant:Nn \prop_put:Nnn { Ne, Nen }
\cs_generate_variant:Nn \__tf_find_index:nN { VN }

% Check if a game label is in the resolved tags
\prg_new_conditional:Nnn \__tf_game_in_tags:n { TF, T, F }
  {
    \prop_if_in:NnTF \l__tf_resolved_tags_prop { #1 }
      { \prg_return_true: }
      { \prg_return_false: }
  }

\cs_generate_variant:Nn \__tf_game_in_tags:nTF { VTF }
\cs_generate_variant:Nn \__tf_game_in_tags:nT { VT }

